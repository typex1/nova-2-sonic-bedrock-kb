# AWS region for Bedrock (Nova 2 Sonic must be enabled here)
AWS_REGION=us-east-1

# Optional: AWS CLI profile name (omit to use default credential chain)
# AWS_PROFILE=your-profile-name

# Required: Kiro API key for headless mode
# Generate at https://app.kiro.dev (requires Pro/Pro+/Power subscription)
KIRO_API_KEY=your-kiro-api-key-here

# Path to kiro-cli binary (default: kiro-cli from PATH)
# KIRO_CLI_PATH=/usr/local/bin/kiro-cli

# Working directory for Kiro CLI
# KIRO_WORKSPACE=/path/to/your/project

# Timeout for Kiro commands in ms (default: 120000)
# KIRO_TIMEOUT=120000

# Server port (default: 3000)
# PORT=3000
